<% content_for :title, "Posts" %>

<div class="w-full max-w-4xl p-6 mx-auto">
  <% if notice.present? %>
    <p class="inline-block px-3 py-2 mb-5 font-medium text-green-500 rounded-md bg-green-50" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex items-center justify-between">
    <h1 class="text-4xl font-bold">Posts</h1>
    <%= link_to "New post", new_post_path, class: "rounded-md px-3.5 py-2.5 bg-blue-600 hover:bg-blue-500 text-white block font-medium" %>
  </div>

  <div id="posts" class="min-w-full mt-6">
    <% if @posts.any? %>
      <% @posts.each do |post| %>
        <%= render 'post', post: post %>
        <p>
          <%= link_to "Show this post", post, class: "ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
        </p>
      <% end %>
    <% else %>
      <p class="my-10 text-center">No posts found.</p>
    <% end %>
  </div>
</div>