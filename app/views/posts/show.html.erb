<% content_for :title, "Showing post" %>

<div class="w-full md:w-2/3">
  <% if notice.present? %>
    <p class="inline-block px-3 py-2 mb-5 font-medium text-green-500 rounded-md bg-green-50" id="notice"><%= notice %></p>
  <% end %>
  <div class="flex items-center justify-between">
    <h1 class="text-4xl font-bold">Showing post</h1>
    <%= link_to "Back to posts", posts_path, class: "ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  </div>
  
  <h1 class="text-4xl font-bold"><%= @post.title %></h1>
  <p class="mt-4 text-lg"><%= @post.content %></p>
  <p class="text-sm text-gray-500">Posted by <%= @post.user.email %></p>
  
    <div class="flex items-center mt-6">
      <% if user_signed_in? && @post.user == current_user %>
        <%= link_to "Edit this post", edit_post_path(@post), class: "ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
        <%= button_to "Destroy this post", @post, method: :delete, class: "ml-2 rounded-md px-3.5 py-2.5 bg-red-600 hover:bg-red-200 inline-block font-medium" %>
    <% end %>
    </div>
</div>
